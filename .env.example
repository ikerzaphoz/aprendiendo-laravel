# ============================================================
# ARCHIVO DE CONFIGURACIÓN DE LARAVEL
# ============================================================
# Este archivo es una PLANTILLA. Nunca se sube a Git con datos reales.
# Cada desarrollador copia este archivo como ".env" y pone sus valores.
#
# En PHP nativo hacías: define('DB_HOST', 'localhost'); en config.php
# En Laravel todo va aquí y se accede con env('DB_HOST')
# ============================================================

# Nombre de tu aplicación (aparece en emails, títulos, etc.)
APP_NAME="Aprendiendo Laravel"

# Entorno: local | staging | production
# En producción SIEMPRE debe ser "production"
APP_ENV=local

# Clave secreta de la app (se genera con: php artisan key:generate)
# Nunca la compartas. Se usa para cifrar sesiones y cookies.
APP_KEY=

# Modo debug: true muestra errores detallados, false los oculta
# En producción SIEMPRE debe ser false
APP_DEBUG=true

# URL base de tu aplicación
APP_URL=http://localhost

# ============================================================
# BASE DE DATOS
# ============================================================
# En PHP nativo: $pdo = new PDO('mysql:host=localhost;dbname=mi_bd', 'root', '');
# En Laravel configuras aquí y Eloquent conecta automáticamente

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=aprendiendo_laravel    # ← Cambia esto por tu nombre de BD
DB_USERNAME=root                   # ← Cambia esto por tu usuario MySQL
DB_PASSWORD=                       # ← Cambia esto por tu contraseña MySQL

# ============================================================
# SESIONES
# ============================================================
# Dónde guardar las sesiones: file | database | redis | cookie
# "file" es lo más simple para empezar (como session_start() en PHP nativo)
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# ============================================================
# CACHÉ
# ============================================================
# Sistema de caché: database | file | redis | memcached
CACHE_STORE=database
CACHE_PREFIX=

# ============================================================
# COLA DE TRABAJOS (Jobs/Queues)
# ============================================================
# Para tareas en segundo plano (emails, notificaciones, etc.)
# "sync" = se ejecutan inmediatamente (para desarrollo)
QUEUE_CONNECTION=database

# ============================================================
# CORREO ELECTRÓNICO
# ============================================================
# En PHP nativo usabas PHPMailer o mail()
# Laravel tiene su propio sistema de emails
MAIL_MAILER=log          # "log" escribe en storage/logs en vez de enviar (útil en desarrollo)
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ============================================================
# ALMACENAMIENTO DE ARCHIVOS
# ============================================================
FILESYSTEM_DISK=local

# ============================================================
# VITE (compilador de assets: CSS y JavaScript)
# ============================================================
VITE_APP_NAME="${APP_NAME}"
